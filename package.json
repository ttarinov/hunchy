{
  "name": "hunchy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "deploy": "bash scripts/deploy.sh",
    "deployx": "node scripts/deploy-interactive.mjs",
    "devx": "node scripts/dev-interactive.mjs"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.2.0",
    "@types/inquirer": "^9.0.9",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "inquirer": "^13.2.0",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}